---
import { Image } from 'astro:assets';
import Layout from '../../layouts/Layout.astro';
import {
	formatBlogDate,
	getBlogBySlug,
	getBlogImageUrl,
	renderBlogContent,
} from '../../lib/blogApi';

export const prerender = false;

const { slug } = Astro.params;
const blog = slug ? await getBlogBySlug(slug) : null;
const thumbnail = getBlogImageUrl(blog?.thumbnail);
const contentHtml = renderBlogContent(blog?.content);

if (!blog) {
	Astro.response.status = 404;
}
---

<Layout
	title={blog ? `${blog.title} - Pondok Pesantren Mambaul Hikmah` : 'Blog Tidak Ditemukan - Pondok Pesantren Mambaul Hikmah'}
	description={blog?.excerpt ?? 'Artikel blog tidak ditemukan.'}
>
	<main class="page">
		{blog ? (
			<article class="article">
				<header class="article-header">
					<a class="back-link" href="/blog">Kembali ke Blog</a>
					<p class="meta">
						{formatBlogDate(blog.created_at)}
						{blog.category ? ` • ${blog.category}` : ''}
						{blog.author ? ` • ${blog.author}` : ''}
					</p>
					<h1>{blog.title}</h1>
					{blog.excerpt && <p class="excerpt">{blog.excerpt}</p>}
				</header>

				{thumbnail ? (
					<Image
						class="article-image"
						src={thumbnail}
						width={1200}
						height={675}
						alt=""
						loading="eager"
						decoding="async"
					/>
				) : (
					<div class="article-placeholder">MH</div>
				)}

				<div class="article-content" set:html={contentHtml} />
			</article>
		) : (
			<section class="not-found">
				<a class="back-link" href="/blog">Kembali ke Blog</a>
				<h1>Artikel tidak ditemukan.</h1>
				<p>
					Slug <strong>{slug}</strong> tidak ditemukan di API smart.mambaulhikmah.com.
					Pastikan artikel sudah berstatus published.
				</p>
			</section>
		)}
	</main>
</Layout>

<style>
	.page {
		background: #f8fafa;
	}

	.article {
		max-width: 980px;
		margin: 0 auto;
		padding: 150px 20px 72px;
	}

	.not-found {
		max-width: 760px;
		margin: 0 auto;
		padding: 150px 20px 90px;
	}

	.not-found p {
		color: #465354;
		line-height: 1.75;
	}

	.article-header {
		margin-bottom: 28px;
	}

	.back-link {
		display: inline-flex;
		margin-bottom: 24px;
		color: #004d4c;
		font-size: 0.88rem;
		font-weight: 900;
		text-decoration: none;
	}

	.meta {
		margin: 0 0 12px;
		color: #006766;
		font-size: 0.82rem;
		font-weight: 900;
	}

	h1 {
		margin: 0;
		color: #004d4c;
		font-family: Manrope, Inter, ui-sans-serif, system-ui, sans-serif;
		font-size: clamp(2rem, 4.5vw, 3.7rem);
		line-height: 1.08;
		letter-spacing: -0.035em;
	}

	.excerpt {
		max-width: 760px;
		color: #465354;
		font-size: 1.05rem;
		line-height: 1.75;
	}

	.article-image,
	.article-placeholder {
		width: 100%;
		aspect-ratio: 16 / 9;
		border-radius: 28px;
	}

	.article-image {
		object-fit: cover;
	}

	.article-placeholder {
		display: grid;
		place-items: center;
		background: linear-gradient(135deg, #004d4c, #006766);
		color: #ffffff;
		font-size: 2.4rem;
		font-weight: 950;
	}

	.article-content {
		margin-top: 34px;
		padding: clamp(24px, 5vw, 44px);
		border-radius: 28px;
		background: #ffffff;
		color: #263233;
		line-height: 1.85;
	}

	.article-content :global(h2),
	.article-content :global(h3) {
		margin-top: 1.5em;
		color: #004d4c;
		line-height: 1.2;
	}

	.article-content :global(h2) {
		font-size: clamp(1.55rem, 3vw, 2.1rem);
	}

	.article-content :global(h3) {
		font-size: clamp(1.25rem, 2.4vw, 1.55rem);
	}

	.article-content :global(p) {
		margin: 0 0 1.1em;
	}

	.article-content :global(blockquote) {
		margin: 1.5em 0;
		padding: 18px 22px;
		border-left: 5px solid #c89b3c;
		border-radius: 0 14px 14px 0;
		background: #f8fafa;
		color: #263233;
		font-style: italic;
	}

	.article-content :global(blockquote p:last-child) {
		margin-bottom: 0;
	}

	.article-content :global(.arabic-text) {
		margin: 1.4em 0;
		color: #102728;
		font-size: clamp(1.35rem, 3vw, 1.9rem);
		line-height: 2.15;
		text-align: right;
	}

	.article-content :global(.article-citation) {
		color: #657172;
		font-size: 0.92rem;
		font-style: italic;
	}

	.article-content :global(img) {
		max-width: 100%;
		height: auto;
		border-radius: 18px;
	}
</style>
