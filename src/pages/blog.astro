---
import { Image } from 'astro:assets';
import Layout from '../layouts/Layout.astro';
import { formatBlogDate, getBlogImageUrl, getBlogs } from '../lib/blogApi';

const currentPage = Number(Astro.url.searchParams.get('page') ?? '1');
const blogs = await getBlogs({ page: currentPage, perPage: 9 });
---

<Layout
	title="Blog - Pondok Pesantren Mambaul Hikmah"
	description="Berita dan artikel terbaru Pondok Pesantren Mambaul Hikmah Tegalwangi."
>
	<main class="page">
		<section class="page-hero">
			<p class="eyebrow">Blog & Berita</p>
			<h1>Catatan kegiatan Pondok Pesantren Mambaul Hikmah.</h1>
			<p>
				Informasi kegiatan santri, program pendidikan, dan kabar terbaru dari lingkungan
				pesantren.
			</p>
		</section>

		<section class="blog-grid" aria-label="Daftar artikel">
			{blogs.data.length > 0 ? (
				blogs.data.map((post) => (
					<article class="blog-card">
						{getBlogImageUrl(post.thumbnail) ? (
							<Image
								src={getBlogImageUrl(post.thumbnail) ?? ''}
								width={1200}
								height={675}
								alt=""
								loading="lazy"
								decoding="async"
							/>
						) : (
							<div class="blog-placeholder">MH</div>
						)}
						<div>
							<span>{formatBlogDate(post.created_at)}{post.category ? ` • ${post.category}` : ''}</span>
							<h2>{post.title}</h2>
							<p>{post.excerpt}</p>
							<a href={`/blog/${post.slug}`}>Baca Selengkapnya</a>
						</div>
					</article>
				))
			) : (
				<div class="empty-state">
					<h2>Belum ada artikel yang dipublikasikan.</h2>
					<p>Artikel dari smart.mambaulhikmah.com akan tampil otomatis setelah dipublikasikan.</p>
				</div>
			)}
		</section>

		{blogs.last_page > 1 && (
			<nav class="pagination" aria-label="Pagination blog">
				{Array.from({ length: blogs.last_page }, (_, index) => index + 1).map((page) => (
					<a class={page === blogs.current_page ? 'active' : ''} href={`/blog?page=${page}`}>
						{page}
					</a>
				))}
			</nav>
		)}
	</main>
</Layout>

<style>
	.page {
		background: #f8fafa;
	}

	.page-hero {
		padding: 160px clamp(20px, 6vw, 88px) 64px;
		background:
			radial-gradient(circle at 82% 18%, rgba(134, 212, 210, 0.28), transparent 28%),
			linear-gradient(135deg, #004d4c, #006766);
		color: #ffffff;
	}

	.eyebrow {
		margin: 0 0 12px;
		color: #a2f0ee;
		font-size: 0.72rem;
		font-weight: 950;
		letter-spacing: 0.16em;
		text-transform: uppercase;
	}

	h1 {
		max-width: 820px;
		margin: 0;
		font-family: Manrope, Inter, ui-sans-serif, system-ui, sans-serif;
		font-size: clamp(2rem, 4vw, 3.5rem);
		line-height: 1.08;
		letter-spacing: -0.035em;
	}

	.page-hero p:not(.eyebrow) {
		max-width: 650px;
		color: rgba(255, 255, 255, 0.82);
		line-height: 1.75;
	}

	.blog-grid {
		display: grid;
		grid-template-columns: repeat(3, minmax(0, 1fr));
		gap: 18px;
		padding: 64px clamp(20px, 6vw, 88px);
	}

	.blog-card {
		overflow: hidden;
		border-radius: 28px;
		background: #f2f4f4;
		transition: transform 220ms ease;
	}

	.blog-card:hover {
		transform: translateY(-8px);
	}

	.blog-card img {
		width: 100%;
		aspect-ratio: 16 / 10;
		object-fit: cover;
	}

	.blog-placeholder {
		display: grid;
		width: 100%;
		aspect-ratio: 16 / 10;
		place-items: center;
		background: linear-gradient(135deg, #004d4c, #006766);
		color: #ffffff;
		font-size: 2rem;
		font-weight: 950;
	}

	.blog-card div {
		padding: 24px;
	}

	.blog-card span {
		color: #006766;
		font-size: 0.78rem;
		font-weight: 950;
	}

	.blog-card h2 {
		margin: 12px 0 0;
		color: #004d4c;
		font-size: 1.12rem;
		line-height: 1.3;
	}

	.blog-card p {
		color: #596465;
		line-height: 1.75;
	}

	.blog-card a {
		display: inline-flex;
		margin-top: 8px;
		color: #004d4c;
		font-weight: 950;
		text-decoration: none;
	}

	.empty-state {
		grid-column: 1 / -1;
		padding: clamp(26px, 5vw, 48px);
		border-radius: 28px;
		background: #f2f4f4;
	}

	.empty-state h2 {
		margin: 0;
		color: #004d4c;
		font-size: 1.35rem;
	}

	.empty-state p {
		margin: 10px 0 0;
		color: #596465;
		line-height: 1.75;
	}

	.pagination {
		display: flex;
		flex-wrap: wrap;
		gap: 10px;
		padding: 0 clamp(20px, 6vw, 88px) 64px;
	}

	.pagination a {
		display: grid;
		width: 42px;
		height: 42px;
		place-items: center;
		border-radius: 12px;
		background: #f2f4f4;
		color: #004d4c;
		font-weight: 900;
		text-decoration: none;
	}

	.pagination a.active {
		background: #004d4c;
		color: #ffffff;
	}

	@media (max-width: 980px) {
		.blog-grid {
			grid-template-columns: 1fr;
		}
	}
</style>
