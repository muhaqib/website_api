---
import BlogArchive from '../components/BlogArchive.astro';
import Layout from '../layouts/Layout.astro';
import { getBlogs } from '../lib/blogApi';

const blogs = await getBlogs({ page: 1, perPage: 9 });
---

<Layout
	title="Blog - Pondok Pesantren Mambaul Hikmah"
	description="Berita dan artikel terbaru Pondok Pesantren Mambaul Hikmah Tegalwangi."
>
	<BlogArchive blogs={blogs} />
</Layout>
