---
import { Image } from 'astro:assets';
import Layout from '../layouts/Layout.astro';
import banner4 from '../assets/images/Banner4.jpg';
import { missions } from '../data/site';
---

<Layout
	title="Tentang Kami - Pondok Pesantren Mambaul Hikmah"
	description="Profil, visi, misi, dan motto Pondok Pesantren Mambaul Hikmah Tegalwangi."
>
	<main class="page">
		<section class="page-hero">
			<div>
				<p class="eyebrow">Tentang Kami</p>
				<h1>Pondok Pesantren Mambaul Hikmah Tegalwangi.</h1>
				<p>
					Lembaga pendidikan Islam di Desa Tegalwangi, Kecamatan Talang, Kabupaten Tegal
					yang berfokus pada ilmu agama, pembentukan karakter, dan pembiasaan akhlak santri.
				</p>
			</div>
			<Image src={banner4} alt="Masjid Pondok Pesantren Mambaul Hikmah" loading="eager" />
		</section>

		<section class="content-grid">
			<article class="card wide">
				<p class="eyebrow">Profil Singkat</p>
				<h2>Ruang tumbuh santri yang dekat, tenang, dan terarah.</h2>
				<p>
					Pondok Pesantren Mambaul Hikmah terletak di Desa Tegalwangi, Kecamatan Talang,
					Kabupaten Tegal. Letaknya yang strategis dan mudah dijangkau menjadikan pesantren
					ini berkembang sebagai lembaga pendidikan Islam yang tidak hanya berfokus pada ilmu
					agama, tetapi juga pembentukan karakter santri.
				</p>
			</article>

			<article class="card dark">
				<p class="eyebrow">Visi</p>
				<h2>Membentuk santri yang Beriman, Bertakwa, Berilmu, dan Berakhlak.</h2>
			</article>

			<article class="card">
				<p class="eyebrow">Misi</p>
				<ul>
					{missions.map((mission) => <li>{mission}</li>)}
				</ul>
			</article>

			<article class="card motto">
				<p class="eyebrow">Motto</p>
				<h2>Ilmu, Amal, Tazkiyah</h2>
				<p>Ilmu yang diamalkan, amal yang menyucikan, dan adab yang menenteramkan.</p>
			</article>
		</section>
	</main>
</Layout>

<style>
	.page {
		background: #f8fafa;
	}

	.page-hero {
		display: grid;
		grid-template-columns: minmax(0, 1fr) minmax(280px, 0.75fr);
		gap: clamp(28px, 6vw, 72px);
		align-items: center;
		padding: 160px clamp(20px, 6vw, 88px) 72px;
		background: #f2f4f4;
	}

	.eyebrow {
		margin: 0 0 12px;
		color: #006766;
		font-size: 0.72rem;
		font-weight: 950;
		letter-spacing: 0.16em;
		text-transform: uppercase;
	}

	h1,
	h2 {
		margin: 0;
		color: #004d4c;
		font-family: Manrope, Inter, ui-sans-serif, system-ui, sans-serif;
		letter-spacing: -0.035em;
	}

	h1 {
		max-width: 780px;
		font-size: clamp(2rem, 4vw, 3.5rem);
		line-height: 1.08;
	}

	h2 {
		font-size: clamp(1.4rem, 2.8vw, 2.3rem);
		line-height: 1.14;
	}

	p,
	li {
		color: #465354;
		line-height: 1.75;
	}

	.page-hero img {
		width: 100%;
		aspect-ratio: 4 / 3;
		object-fit: cover;
		border-radius: 28px;
	}

	.content-grid {
		display: grid;
		grid-template-columns: 1.1fr 0.9fr;
		gap: 18px;
		padding: 64px clamp(20px, 6vw, 88px);
	}

	.card {
		padding: clamp(24px, 4vw, 38px);
		border-radius: 28px;
		background: #ffffff;
	}

	.wide {
		grid-row: span 2;
	}

	.dark {
		background: linear-gradient(135deg, #004d4c, #006766);
	}

	.dark .eyebrow,
	.dark h2 {
		color: #ffffff;
	}

	.motto {
		background: #e6e8e8;
	}

	.motto h2 {
		color: #755b00;
		font-style: italic;
	}

	ul {
		display: grid;
		gap: 12px;
		margin: 0;
		padding: 0;
		list-style: none;
	}

	li {
		padding: 13px 15px;
		border-radius: 16px;
		background: #f2f4f4;
		font-weight: 750;
	}

	@media (max-width: 980px) {
		.page-hero,
		.content-grid {
			grid-template-columns: 1fr;
		}

		.wide {
			grid-row: auto;
		}
	}
</style>
