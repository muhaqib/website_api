---
import { Image } from 'astro:assets';
import Layout from '../layouts/Layout.astro';
import banner1 from '../assets/images/Banner1.png';
import { whatsappDisplay, whatsappHref } from '../data/site';

const requirements = [
	'Mengisi formulir pendaftaran santri baru.',
	'Menyiapkan fotokopi KK, akta kelahiran, dan dokumen sekolah terakhir.',
	'Mengikuti jadwal wawancara atau observasi sesuai arahan panitia.',
	'Menghubungi admin untuk konfirmasi unit pendidikan yang dituju.',
];
---

<Layout
	title="Info Pendaftaran - Pondok Pesantren Mambaul Hikmah"
	description="Informasi penerimaan santri baru Pondok Pesantren Mambaul Hikmah Tegalwangi."
>
	<main class="page">
		<section class="page-hero">
			<div>
				<p class="eyebrow">Info Pendaftaran</p>
				<h1>Penerimaan Santri Baru Pondok Pesantren Mambaul Hikmah.</h1>
				<p>
					Konsultasikan pilihan unit pendidikan, jadwal kunjungan pondok, dan proses
					pendaftaran langsung melalui admin.
				</p>
				<div class="actions">
					<a class="btn primary" href={whatsappHref}>Chat WhatsApp {whatsappDisplay}</a>
					<a class="btn soft" href="/tentang-kami">Lihat Profil</a>
				</div>
			</div>
			<Image src={banner1} alt="Santri Pondok Pesantren Mambaul Hikmah" loading="eager" />
		</section>

		<section class="info-grid">
			<article class="card">
				<p class="eyebrow">Alur Pendaftaran</p>
				<h2>Langkah awal bergabung bersama Mambaul Hikmah.</h2>
				<ul>
					{requirements.map((item) => <li>{item}</li>)}
				</ul>
			</article>

			<article class="card highlight">
				<p class="eyebrow">Kontak Admin</p>
				<h2>{whatsappDisplay}</h2>
				<p>
					Admin pendaftaran siap membantu informasi biaya, jadwal, persyaratan, dan
					ketersediaan kuota.
				</p>
				<a class="btn gold" href={whatsappHref}>Hubungi Sekarang</a>
			</article>
		</section>
	</main>
</Layout>

<style>
	.page {
		background: #f8fafa;
	}

	.page-hero {
		display: grid;
		grid-template-columns: minmax(0, 1fr) minmax(280px, 0.78fr);
		gap: clamp(28px, 6vw, 72px);
		align-items: center;
		padding: 160px clamp(20px, 6vw, 88px) 72px;
		background:
			radial-gradient(circle at 82% 18%, rgba(134, 212, 210, 0.2), transparent 28%),
			#f2f4f4;
	}

	.eyebrow {
		margin: 0 0 12px;
		color: #006766;
		font-size: 0.72rem;
		font-weight: 950;
		letter-spacing: 0.16em;
		text-transform: uppercase;
	}

	h1,
	h2 {
		margin: 0;
		color: #004d4c;
		font-family: Manrope, Inter, ui-sans-serif, system-ui, sans-serif;
		letter-spacing: -0.035em;
	}

	h1 {
		max-width: 820px;
		font-size: clamp(2rem, 4vw, 3.5rem);
		line-height: 1.08;
	}

	h2 {
		font-size: clamp(1.4rem, 2.8vw, 2.3rem);
		line-height: 1.14;
	}

	p,
	li {
		color: #465354;
		line-height: 1.75;
	}

	.page-hero img {
		width: 100%;
		aspect-ratio: 4 / 3;
		object-fit: cover;
		border-radius: 28px;
	}

	.actions {
		display: flex;
		flex-wrap: wrap;
		gap: 12px;
		margin-top: 26px;
	}

	.btn {
		display: inline-flex;
		min-height: 44px;
		align-items: center;
		justify-content: center;
		padding: 0 18px;
		border-radius: 12px;
		font-size: 0.86rem;
		font-weight: 900;
		text-decoration: none;
	}

	.primary {
		background: #004d4c;
		color: #ffffff;
	}

	.soft {
		background: #a2f0ee;
		color: #00504f;
	}

	.gold {
		margin-top: 12px;
		background: #cca73b;
		color: #211b00;
	}

	.info-grid {
		display: grid;
		grid-template-columns: minmax(0, 1fr) minmax(280px, 0.72fr);
		gap: 18px;
		padding: 64px clamp(20px, 6vw, 88px);
	}

	.card {
		padding: clamp(24px, 4vw, 38px);
		border-radius: 28px;
		background: #ffffff;
	}

	.highlight {
		background: linear-gradient(135deg, #004d4c, #006766);
	}

	.highlight .eyebrow,
	.highlight h2,
	.highlight p {
		color: #ffffff;
	}

	ul {
		display: grid;
		gap: 12px;
		margin: 24px 0 0;
		padding: 0;
		list-style: none;
	}

	li {
		padding: 13px 15px;
		border-radius: 16px;
		background: #f2f4f4;
		font-weight: 750;
	}

	@media (max-width: 980px) {
		.page-hero,
		.info-grid {
			grid-template-columns: 1fr;
		}
	}
</style>
