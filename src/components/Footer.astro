---
import { Image } from 'astro:assets';
import logo from '../assets/logo.png';

const whatsappDisplay = '+62 813-9375-0612';
const whatsappHref = 'https://wa.me/6281393750612';
---

<footer class="site-footer" id="kontak">
	<div class="footer-main reveal">
		<a class="brand footer-brand" href="/">
			<Image src={logo} width={64} height={64} alt="Logo Pondok Pesantren Mambaul Hikmah" />
			<span>
				<strong>Pondok Pesantren Mambaul Hikmah</strong>
				<small>Tegalwangi - Talang - Tegal</small>
			</span>
		</a>
		<p>
			Media informasi resmi untuk mengenalkan profil, visi-misi, program pendidikan, dan kegiatan
			Pondok Pesantren Mambaul Hikmah.
		</p>
	</div>

	<div class="footer-card reveal delay-1">
		<h2>Kontak</h2>
		<p>Desa Tegalwangi, Kecamatan Talang, Kabupaten Tegal</p>
		<a href={whatsappHref}>WhatsApp Admin: {whatsappDisplay}</a>
		<a href="mailto:info@mambaulhikmah.sch.id">info@mambaulhikmah.sch.id</a>
	</div>
</footer>

<style>
	.site-footer {
		display: grid;
		grid-template-columns: minmax(0, 1fr) minmax(260px, 0.45fr);
		gap: 28px;
		padding: 52px clamp(20px, 6vw, 88px) 36px;
		background: #f2f4f4;
	}

	.footer-main,
	.footer-card {
		padding: 28px;
		border-radius: 28px;
		background: #ffffff;
	}

	.brand {
		display: inline-flex;
		align-items: center;
		gap: 12px;
		min-width: 0;
		color: inherit;
		text-decoration: none;
	}

	.footer-brand {
		margin-bottom: 16px;
	}

	.brand img {
		width: 56px;
		height: 56px;
		object-fit: contain;
		filter: drop-shadow(0 12px 18px rgba(0, 77, 76, 0.14));
	}

	.brand span {
		display: grid;
		min-width: 0;
	}

	.brand strong {
		color: #004d4c;
		font-family:
			Manrope, Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI",
			sans-serif;
		font-size: clamp(0.9rem, 1.3vw, 1.05rem);
		line-height: 1.1;
	}

	.brand small {
		margin-top: 3px;
		color: #596465;
		font-size: 0.72rem;
		font-weight: 700;
	}

	.footer-main p {
		max-width: 680px;
		color: #465354;
		font-size: clamp(0.94rem, 1.1vw, 1rem);
		line-height: 1.75;
	}

	.footer-card {
		display: grid;
		align-content: start;
		gap: 10px;
	}

	.footer-card h2 {
		margin: 0 0 4px;
		color: #004d4c;
		font-size: 1.2rem;
	}

	.footer-card p,
	.footer-card a {
		margin: 0;
		color: #465354;
		line-height: 1.7;
		text-decoration: none;
	}

	.footer-card a:hover {
		color: #004d4c;
	}

	@media (max-width: 1180px) {
		.site-footer {
			grid-template-columns: 1fr;
		}
	}

	@media (max-width: 760px) {
		.site-footer {
			grid-template-columns: 1fr;
		}
	}
</style>
